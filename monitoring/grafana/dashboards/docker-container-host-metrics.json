    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "🖥️ Host / Node Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(process_cpu_seconds_total[$interval])) * 100",
          "intervalFactor": 2,
          "legendFormat": "host",
          "refId": "C",
          "step": 4
        }
      ],
      "title": "CPU Usage on Node",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Available Memory" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#7EB26D", "mode": "fixed" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Unavailable Memory" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#BF1B00", "mode": "fixed" }
              }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 6 },
      "id": 20,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemAvailable_bytes",
          "format": "time_series",
          "intervalFactor": 2,
          "legendFormat": "Available Memory",
          "refId": "H",
          "step": 4
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "format": "time_series",
          "intervalFactor": 2,
          "legendFormat": "Unavailable Memory",
          "refId": "G",
          "step": 4
        }
      ],
      "title": "Available Memory on Node",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 6 },
      "id": 13,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_filesystem_avail_bytes{fstype=~\"ext4|xfs|btrfs\"}",
          "format": "time_series",
          "intervalFactor": 2,
          "legendFormat": "Free: {{mountpoint}}",
          "refId": "A",
          "step": 4
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_filesystem_size_bytes{fstype=~\"ext4|xfs|btrfs\"} - node_filesystem_avail_bytes{fstype=~\"ext4|xfs|btrfs\"}",
          "format": "time_series",
          "intervalFactor": 2,
          "legendFormat": "Used Disk Space",
          "refId": "B",
          "step": 4
        }
      ],
      "title": "Free and Used Disk Space on Node",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_disk_read_bytes_total[$interval])) by (device)",
          "intervalFactor": 2,
          "legendFormat": "READ /{{device}}",
          "refId": "A",
          "step": 4
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(node_disk_written_bytes_total[$interval])) by (device)",
          "intervalFactor": 2,
          "legendFormat": "WRITE /{{device}}",
          "refId": "B",
          "step": 4
        }
      ],
      "title": "Disk I/O on Node",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
