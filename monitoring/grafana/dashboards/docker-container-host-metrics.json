    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "SENT" },
            "properties": [
              {
                "id": "color",
                "value": { "fixedColor": "#BF1B00", "mode": "fixed" }
