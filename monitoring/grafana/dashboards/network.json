{
  "dashboard": {
    "title": "Network Dashboard",
    "description": "Network traffic overview",
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "type": "timeseries",
        "title": "Network Receive Traffic",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "datasource": "prometheus",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m])",
            "refId": "A"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Network Transmit Traffic",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "datasource": "prometheus",
        "targets": [
          {
            "expr": "rate(node_network_transmit_bytes_total[5m])",
            "refId": "A"
          }
        ]
      },
      {
        "type": "timeseries",
        "title": "Total Network Traffic",
        "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
        "datasource": "prometheus",
        "targets": [
          {
            "expr": "rate(node_network_receive_bytes_total[5m]) + rate(node_network_transmit_bytes_total[5m])",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
