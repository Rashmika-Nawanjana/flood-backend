APP_NAME=Flood Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

SENSOR_OFFLINE_MINUTES=15

# Local service ports
FRONTEND_PORT=14000
API_PORT=8002   
KEYCLOAK_PORT=8080
POSTGRES_PORT=5432
INFLUXDB_PORT=8086

# Local service URLs
FRONTEND_URL=http://localhost:14000
BACKEND_URL=http://localhost:8000
KEYCLOAK_URL=http://localhost:8080

# CORS
ALLOWED_ORIGINS=http://localhost:14000

# Clerk
CLERK_JWKS_URL=https://useful-hen-13.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://useful-hen-13.clerk.accounts.dev
# Create this secret from the Clerk webhook endpoint settings.
# It is required for local ngrok webhook verification and hosted webhooks.
CLERK_WEBHOOK_SECRET=

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=flooddb
DATABASE_URL=postgresql+psycopg://admin:admin@localhost:5432/flooddb

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=flood
INFLUXDB_BUCKET=telemetry
INFLUXDB_TOKEN=my-super-secret-token-12345
INFLUXDB_PORT=8086
INFLUXDB_HOST=influxdb

# MQTT → Kafka → InfluxDB Pipeline
MQTT_BROKER=mosquitto
MQTT_PORT=1883
MQTT_TOPIC=flood/sensors/#
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=flood-sensor-data

# Anomaly Detection (Intelligence Service)
ANOMALY_DETECTOR_INPUT_TOPIC=flood-sensor-data
ANOMALY_DETECTOR_OUTPUT_TOPIC=system.alerts
# Kong Konnect Configuration (for production deployment)
# Get values from: docs/KONNECT_CONFIG_GUIDE.md
KONNECT_TOKEN=kpat_YOUR_TOKEN_HERE
KONNECT_ADDR=https://in.api.konghq.com
CONTROL_PLANE_NAME=Flood-Management-Gateway
KONNECT_NODE_NAME=flood-stg-node