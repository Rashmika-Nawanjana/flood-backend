{
  "title": "Flood Services — API Performance",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"api\"}[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API Latency",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum{job=\"api\"}[5m]) / rate(http_request_duration_seconds_count{job=\"api\"}[5m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Sensor Service Requests",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"sensor-service\"}[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Zone Service Requests",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"zone-service\"}[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Intelligence Service Requests",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"intelligence-service\"}[1m])"
        }
      ]
    }
  ]
}
