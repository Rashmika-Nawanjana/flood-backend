        "query": "30s,1m,2m,5m,10m,30m,1h,6h,1d",
        "refresh": 2,
        "skipUrlSync": false,
        "type": "interval"
      },
      {
        "current": { "text": "", "value": "" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(container_cpu_user_seconds_total, job)",
        "hide": 0,
