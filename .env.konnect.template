# Kong Konnect Configuration Template
# This file stores your Kong Konnect connection details
# IMPORTANT: DO NOT commit this file to git - add it to .gitignore
#
# How to get these values? See: docs/KONNECT_CONFIG_GUIDE.md
#
# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Your Kong Konnect API Token (REQUIRED)
# Get from: https://cloud.konghq.com → Settings → Personal Access Tokens
# Generate new token and copy (starts with "kpat_")
export KONNECT_TOKEN="kpat_OTI5yhVaqImrn9NAFkvlmg4ZwlhBFepBwTge9vStJeRke7pFA"

# Kong Konnect API Address (REQUIRED)
# US (default): https://in.api.konghq.com
# EU: https://eu.api.konghq.com
# AU: https://au.api.konghq.com
export KONNECT_ADDR="https://in.api.konghq.com"

# Your Control Plane name in Kong Konnect (REQUIRED)
# Get from: https://cloud.konghq.com → Gateway Manager → Control Planes
# Create one if it doesn't exist
export CONTROL_PLANE_NAME="Flood-Management-Gateway"

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# Kong Konnect Node name (OPTIONAL)
# Name of your Kong Data Plane running on DigitalOcean
# Used when deploying to identify the node
export KONNECT_NODE_NAME="flood-stg-node"

# Region (OPTIONAL)
# Data center region: us, eu, au
# export KONNECT_REGION="us"

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Copy this file: cp .env.konnect.template .env.konnect
# 2. Get your configuration values (see KONNECT_CONFIG_GUIDE.md)
# 3. Edit: nano .env.konnect
# 4. Test: source .env.konnect && ./scripts/kong-konnect-setup.sh ping
# ============================================
