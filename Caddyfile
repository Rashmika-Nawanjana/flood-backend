{
	email admin@floodsense.lk
}

{$PUBLIC_HOSTNAME} {
	encode gzip

	# Block public access to /metrics endpoints — internal scraping only
	@metrics path /metrics
	respond @metrics 403

	# Socket.IO — long timeouts to keep idle sessions alive between sensor bursts.
	# Routed directly to the API service; Kong does not handle WebSocket upgrades.
	@websockets path /ws/*
	reverse_proxy @websockets api:8000 {
		transport http {
			read_timeout 1h
			write_timeout 1h
		}
	}

	# Grafana monitoring dashboard — proxied under /grafana/
	handle /grafana/* {
		reverse_proxy grafana:3000
	}

	# All other traffic routes through Kong (REST API, auth, rate limiting)
	reverse_proxy kong:8000
}
