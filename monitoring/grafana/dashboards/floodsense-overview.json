{
  "title": "FloodSense - Service Overview",
  "uid": "floodsense-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["floodsense", "overview"],
  "panels": [
    {
      "id": 1,
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[2m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 0.05 }] }
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status_code=~\"5..\"}[2m])) / sum by (service) (rate(http_requests_total[2m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Request Latency p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p95 {{service}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (service, le) (rate(http_request_duration_seconds_bucket[5m]))) * 1000",
          "legendFormat": "p50 {{service}}",
          "refId": "B"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Active HTTP Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "http_requests_in_progress",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Pipeline - MQTT Messages",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(mqtt_messages_received_total[2m])",
          "legendFormat": "Received",
          "refId": "A"
        },
        {
          "expr": "rate(mqtt_messages_forwarded_total[2m])",
          "legendFormat": "Forwarded to Kafka",
          "refId": "B"
        },
        {
          "expr": "rate(mqtt_messages_dropped_total[2m])",
          "legendFormat": "Dropped",
          "refId": "C"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "Pipeline - Kafka→InfluxDB",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(kafka_influx_messages_consumed_total[2m])",
          "legendFormat": "Consumed",
          "refId": "A"
        },
        {
          "expr": "rate(kafka_influx_messages_written_total[2m])",
          "legendFormat": "Written to InfluxDB",
          "refId": "B"
        },
        {
          "expr": "rate(kafka_influx_anomalies_detected_total[2m])",
          "legendFormat": "Anomalies Detected",
          "refId": "C"
        },
        {
          "expr": "rate(kafka_influx_write_errors_total[2m])",
          "legendFormat": "Write Errors",
          "refId": "D"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 8,
      "title": "MQTT Bridge Connection",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 4, "h": 4 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DISCONNECTED", "color": "red" }, "1": { "text": "CONNECTED", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [
        { "expr": "mqtt_connected", "legendFormat": "MQTT Broker", "refId": "A" }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 9,
      "title": "Message Processing Latency p95 (ms)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 28, "w": 8, "h": 4 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(kafka_influx_processing_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "Kafka→InfluxDB p95",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 10,
      "title": "Total Anomalies (last 1h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 4 },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "targets": [
        {
          "expr": "increase(kafka_influx_anomalies_detected_total[1h])",
          "legendFormat": "Anomalies",
          "refId": "A"
        }
      ],
      "datasource": "Prometheus"
    }
  ]
}
