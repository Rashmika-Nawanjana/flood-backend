{
  "__inputs": [],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "name": "Annotations",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "🟢 Service Health Overview",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "targets": [{ "expr": "up{job=\"api\"}", "refId": "A" }],
      "title": "API",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "targets": [{ "expr": "up{job=\"sensor-service\"}", "refId": "A" }],
      "title": "Sensor Service",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "targets": [{ "expr": "up{job=\"zone-service\"}", "refId": "A" }],
      "title": "Zone Service",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 5 },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total[5m]))",
          "refId": "A"
        }
      ],
      "title": "Request Rate by Service",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 5 },
      "id": 6,
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "5xx Errors by Service",
      "type": "timeseries"
    }
  ],
  "schemaVersion": 38,
  "title": "Service Overview Dashboard",
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "version": 1
}
