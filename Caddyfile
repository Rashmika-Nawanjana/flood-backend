{
	email admin@floodsense.lk
}

{$PUBLIC_HOSTNAME} {
	encode gzip

	# Socket.IO at /ws/live — routed directly to the API service, bypassing Kong.
	# Kong runs as a Konnect data plane (cloud-managed routes) and does not have
	# a local /ws route configured. Caddy handles the WebSocket upgrade natively;
	# the long timeout keeps idle Socket.IO sessions alive between sensor bursts.
	@websockets path /ws/*
	reverse_proxy @websockets api:8000 {
		transport http {
			read_timeout 1h
			write_timeout 1h
		}
	}

	# All other traffic routes through Kong (REST API, auth, rate limiting)
	reverse_proxy kong:8000
}
