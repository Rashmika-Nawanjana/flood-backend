APP_NAME=Flood Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

SENSOR_OFFLINE_MINUTES=15

# Local service ports
FRONTEND_PORT=14000
API_PORT=8000
KEYCLOAK_PORT=8080
POSTGRES_PORT=5432
INFLUXDB_PORT=8086

# Local service URLs
FRONTEND_URL=http://localhost:14000
BACKEND_URL=http://localhost:8000
KEYCLOAK_URL=http://localhost:8080

# CORS
ALLOWED_ORIGINS=http://localhost:14000

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=flood-management
KEYCLOAK_CLIENT_ID=flood-frontend
KEYCLOAK_ISSUER=http://localhost:8080/realms/flood-management
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/flood-management/protocol/openid-connect/certs
OIDC_DISCOVERY_URL=http://localhost:8080/realms/flood-management/.well-known/openid-configuration


# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=flooddb
DATABASE_URL=postgresql+psycopg://admin:admin@localhost:5432/flooddb

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=flood
INFLUXDB_BUCKET=telemetry